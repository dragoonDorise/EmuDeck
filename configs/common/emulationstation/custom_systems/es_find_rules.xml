<?xml version="1.0"?>
<!-- ES-DE find rules for EmuDeck.
     Each emulator points to the EmuDeck launcher script so all games
     go through launcher.py (cloud sync, hotkeys, netplay, etc.).
     .EXT is replaced by .sh (Unix) or .bat (Windows) during esde_init().
     EMULATIONPATH is replaced by the actual emulation path. -->
<ruleList>
    <emulator name="OS-SHELL">
        <rule type="systempath">
            <entry>bash</entry>
            <entry>sh</entry>
        </rule>
    </emulator>

    <!-- RetroArch — covers ~50 systems (nes, snes, genesis, gb, gbc, saturn, etc.) -->
    <emulator name="RETROARCH">
        <rule type="staticpath">
            <entry>EMULATIONPATH/tools/launchers/retroarch.EXT</entry>
        </rule>
    </emulator>
    <core name="RETROARCH">
        <rule type="corepath">
            <entry>~/.var/app/org.libretro.RetroArch/config/retroarch/cores</entry>
            <entry>~/snap/retroarch/current/.config/retroarch/cores</entry>
            <entry>~/.config/retroarch/cores</entry>
            <entry>/usr/lib/x86_64-linux-gnu/libretro</entry>
            <entry>/usr/lib64/libretro</entry>
            <entry>/usr/lib/libretro</entry>
            <entry>/usr/local/lib/libretro</entry>
            <entry>/usr/pkg/lib/libretro</entry>
        </rule>
    </core>

    <!-- Dolphin — gc, gamecube, wii -->
    <emulator name="DOLPHIN">
        <rule type="staticpath">
            <entry>EMULATIONPATH/tools/launchers/dolphin-emu.EXT</entry>
        </rule>
    </emulator>

    <!-- PCSX2 — ps2 -->
    <emulator name="PCSX2">
